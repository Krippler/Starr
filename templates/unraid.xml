<?xml version="1.0"?>
<Container version="2">

  <!-- ── Basic metadata ─────────────────────────────────────────────────── -->
  <Name>Starr</Name>
  <Repository>yourdockerhubuser/Starr</Repository>
  <Registry>https://hub.docker.com/r/yourdockerhubuser/Starr</Registry>
  <GitHub>https://github.com/Krippler/Starr</GitHub>
  <Project>https://github.com/Krippler/Starr</Project>
  <Overview>
    Web UI for diagnosing and repairing Sonarr, Radarr, and Lidarr SQLite databases.
    Safely shuts down the target app, creates a timestamped backup, runs SQLite
    PRAGMA repairs (integrity check, FK repair, WAL checkpoint, VACUUM, REINDEX,
    ANALYZE) on the idle database, then prompts you to restart.
    All repair operations are streamed live to the browser terminal.
    Supports dry-run mode. Backups are auto-pruned after a configurable number of days.
  </Overview>

  <!-- ── Appearance ─────────────────────────────────────────────────────── -->
  <Category>Tools: MediaServer:Other</Category>
  <WebUI>http://[IP]:[PORT:8877]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/Krippler/Starr/main/templates/unraid.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/Krippler/Starr/main/docs/icon.png</Icon>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <Support>https://github.com/Krippler/Starr/issues</Support>
  <ReadmeURL>https://github.com/Krippler/Starr/blob/main/README.md</ReadmeURL>

  <!-- ── Networking ─────────────────────────────────────────────────────── -->
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <HostPort>8877</HostPort>
      <ContainerPort>8877</ContainerPort>
      <Protocol>tcp</Protocol>
    </Publish>
  </Networking>

  <!-- ── Volumes ────────────────────────────────────────────────────────── -->

  <!-- Sonarr config directory (contains sonarr.db) -->
  <Volume>
    <HostDir>/mnt/user/appdata/sonarr</HostDir>
    <ContainerDir>/data/sonarr</ContainerDir>
    <Mode>rw</Mode>
  </Volume>

  <!-- Radarr config directory (contains radarr.db) -->
  <Volume>
    <HostDir>/mnt/user/appdata/radarr</HostDir>
    <ContainerDir>/data/radarr</ContainerDir>
    <Mode>rw</Mode>
  </Volume>

  <!-- Lidarr config directory (contains lidarr.db) -->
  <Volume>
    <HostDir>/mnt/user/appdata/lidarr</HostDir>
    <ContainerDir>/data/lidarr</ContainerDir>
    <Mode>rw</Mode>
  </Volume>

  <!-- Backup output directory -->
  <Volume>
    <HostDir>/mnt/user/appdata/Starr/backups</HostDir>
    <ContainerDir>/backups</ContainerDir>
    <Mode>rw</Mode>
  </Volume>

  <!-- ── Environment variables ──────────────────────────────────────────── -->

  <Environment>
    <!-- Web UI port (should match the port mapping above) -->
    <Variable>
      <Name>PORT</Name>
      <Value>8877</Value>
      <Description>Web UI listen port inside the container.</Description>
      <Display>always</Display>
      <Required>true</Required>
      <Mask>false</Mask>
    </Variable>

    <!-- Log verbosity -->
    <Variable>
      <Name>LOG_LEVEL</Name>
      <Value>INFO</Value>
      <Description>Log verbosity: DEBUG, INFO, WARNING, ERROR</Description>
      <Display>advanced</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>

    <!-- Backup retention -->
    <Variable>
      <Name>MAX_BACKUP_AGE_DAYS</Name>
      <Value>7</Value>
      <Description>Number of days to keep backups before auto-pruning.</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>

    <!-- ── Sonarr ── -->
    <Variable>
      <Name>SONARR_HOST</Name>
      <Value></Value>
      <Description>Sonarr hostname or IP. Leave blank to configure in the web UI.</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>SONARR_PORT</Name>
      <Value>8989</Value>
      <Description>Sonarr HTTP port.</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>SONARR_APIKEY</Name>
      <Value></Value>
      <Description>Sonarr API key (Settings › General). Leave blank to enter in the web UI.</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>true</Mask>
    </Variable>
    <Variable>
      <Name>SONARR_URLBASE</Name>
      <Value></Value>
      <Description>Sonarr URL base, e.g. /sonarr (leave blank if none).</Description>
      <Display>advanced</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>

    <!-- ── Radarr ── -->
    <Variable>
      <Name>RADARR_HOST</Name>
      <Value></Value>
      <Description>Radarr hostname or IP.</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>RADARR_PORT</Name>
      <Value>7878</Value>
      <Description>Radarr HTTP port.</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>RADARR_APIKEY</Name>
      <Value></Value>
      <Description>Radarr API key (Settings › General).</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>true</Mask>
    </Variable>
    <Variable>
      <Name>RADARR_URLBASE</Name>
      <Value></Value>
      <Description>Radarr URL base (leave blank if none).</Description>
      <Display>advanced</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>

    <!-- ── Lidarr ── -->
    <Variable>
      <Name>LIDARR_HOST</Name>
      <Value></Value>
      <Description>Lidarr hostname or IP.</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>LIDARR_PORT</Name>
      <Value>8686</Value>
      <Description>Lidarr HTTP port.</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>LIDARR_APIKEY</Name>
      <Value></Value>
      <Description>Lidarr API key (Settings › General).</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>true</Mask>
    </Variable>
    <Variable>
      <Name>LIDARR_URLBASE</Name>
      <Value></Value>
      <Description>Lidarr URL base (leave blank if none).</Description>
      <Display>advanced</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>

  </Environment>

  <!-- ── Labels ─────────────────────────────────────────────────────────── -->
  <Labels/>

</Container>
