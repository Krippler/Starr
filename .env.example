# ── Starr DB Repair — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Web UI
WEB_PORT=8877
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-string
MAX_BACKUP_AGE_DAYS=7

# Runtime user (must own — or share a group with — your *arr config dirs).
# Unraid: 99/100. Most other Linux: 1000/1000.
PUID=1000
PGID=1000

# Host appdata root + backup output. Starr finds each *arr's /config inside
# APPDATA_ROOT via Docker introspection, so no per-app paths are needed.
APPDATA_ROOT=/mnt/user/appdata
BACKUP_PATH=/mnt/user/appdata/starr/backups

# Per-app API keys — the ONLY per-app value Starr needs.
# Leave any of these blank to disable that app.
SONARR_APIKEY=
RADARR_APIKEY=
LIDARR_APIKEY=
SPORTARR_APIKEY=
READARR_APIKEY=
PROWLARR_APIKEY=
WHISPARR_APIKEY=
BAZARR_APIKEY=

# Optional URL overrides — only set if Docker discovery misses the container
# (multiple instances, custom networking, etc). Format: http://host:port[/urlbase].
SONARR_URL=
RADARR_URL=
LIDARR_URL=
SPORTARR_URL=
READARR_URL=
PROWLARR_URL=
WHISPARR_URL=
BAZARR_URL=
