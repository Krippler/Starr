# ── Starr DB Repair  —  Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Web UI
WEB_PORT=8877
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-string
MAX_BACKUP_AGE_DAYS=7

# Local paths to your Starr app config directories
# (the folder that contains sonarr.db / radarr.db / lidarr.db)
SONARR_CONFIG=/mnt/user/appdata/sonarr
RADARR_CONFIG=/mnt/user/appdata/radarr
LIDARR_CONFIG=/mnt/user/appdata/lidarr

# Backup output directory on the host
BACKUP_PATH=/mnt/user/appdata/Starr/backups

# ── Optional: pre-configure connections (can also be set in the web UI) ───────
SONARR_HOST=sonarr
SONARR_PORT=8989
SONARR_APIKEY=
SONARR_URLBASE=

RADARR_HOST=radarr
RADARR_PORT=7878
RADARR_APIKEY=
RADARR_URLBASE=

LIDARR_HOST=lidarr
LIDARR_PORT=8686
LIDARR_APIKEY=
LIDARR_URLBASE=
